<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net48</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <LangVersion>14</LangVersion>
        <IsPackable>false</IsPackable>
    </PropertyGroup>

    <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
      <OutputPath>../Assemblies</OutputPath>
      <DebugSymbols>false</DebugSymbols>
      <DebugType>none</DebugType>
    </PropertyGroup>

    <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
      <OutputPath>../Assemblies</OutputPath>
      <DebugType>none</DebugType>
    </PropertyGroup>

    <ItemGroup>
      <PackageReference Include="Krafs.Rimworld.Ref" Version="1.6.4633" />
      <PackageReference Include="Lib.Harmony.Ref" Version="2.4.2" />
    </ItemGroup>

    <ItemGroup>
      <Folder Include="Patches\ListerBuildings\" />
      <Folder Include="Patches\PawnDiedOrDownedThoughtsUtility\" />
    </ItemGroup>

    <ItemGroup>
      <None Remove="Kingfisher.sln.DotSettings" />
      <None Remove="Kingfisher.csproj.DotSettings" />
    </ItemGroup>

</Project>
